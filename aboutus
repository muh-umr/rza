}

.hero-content h1 {
  font-size: 48px;
  font-weight: 700;
  color: var(--text-dark);
  margin-bottom: 24px;
  line-height: 1.1;
}

.hero-content p {
  font-size: 18px;
  line-height: 1.5;
  color: var(--text-dark);
  margin-bottom: 48px;
}

.hero-buttons {
  display: flex;
  gap: 16px;
}

.hero-image {
  flex: 1;
  display: flex;
  justify-content: flex-end;
}

.image-card {
  border-radius: 10px;
  overflow: hidden;
  box-shadow: 0px 25px 50px -12px rgba(0, 0, 0, 0.25);
  width: 100%;
  max-width: 728px;
}

.image-card img {
  width: 100%;
