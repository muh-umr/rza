  }

  .hero-content h1 {
    font-size: 36px;
  }
}

#features-section {
  padding: 80px 0;
  background-color: #fff;
}

.section-header {
  text-align: center;
  margin-bottom: 48px;
}

.section-header h2 {
  font-size: 32px;
  font-weight: 700;
  color: var(--text-dark);
}

.features-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0; /* Design shows cards touching or specific spacing handled by grid container in Figma */
}

.feature-card {
  background-color: #ffffff;
  border: 1px solid var(--border-color);
  border-radius: 14px;
  padding: 32px 24px;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  margin: 0 12px; /* Adding some margin to separate cards visually if grid gap is 0 */
}

.feature-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24px;
}

.icon-circle {
  width: 64px;
