:root {
  --color-primary: #2b4625;
  --color-secondary: #a86a20;
  --color-bg-light: #f5f5f0;
  --color-white: #ffffff;
  --color-text-dark: #2e2e2e;
  --color-text-grey: #717171;
  --color-border: rgba(46, 46, 46, 0.1);
  --font-main: 'Inter', sans-serif;
}

body {
  font-family: var(--font-main);
  margin: 0;
  padding: 0;
  background-color: var(--color-bg-light);
  color: var(--color-text-dark);
  -webkit-font-smoothing: antialiased;
}

*,
*::before,
*::after {
  box-sizing: border-box;
}

img {
  display: block;
  max-width: 100%;
  height: auto;
}

button {
  font-family: inherit;
  cursor: pointer;
  border: none;
  background: none;
}

.container {
  width: 100%;
  max-width: 1536px;
  margin: 0 auto;
  padding: 0 16px;
}

/* Utility for flex centering */
.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.site-header {
  background-color: var(--color-primary);
  color: var(--color-bg-light);
  padding: 16px 0;
}

.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
}

.header-left .logo {
  display: flex;
  align-items: center;
  gap: 8px;
  text-decoration: none;
  color: inherit;
}

.logo-icon {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-text {
  display: flex;
  flex-direction: column;
}

.brand-name {
  font-weight: 700;
  font-size: 16px;
  line-height: 1.2;
}

.brand-tagline {
  font-size: 12px;
  opacity: 0.7;
}

.header-nav {
  display: none; /* Hidden on small mobile, visible on desktop */
}

.nav-link {
  color: var(--color-bg-light);
  text-decoration: none;
  margin: 0 12px;
  font-size: 16px;
  font-weight: 500;
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 16px;
}

.icon-btn {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.btn-login {
  display: flex;
  align-items: center;
  gap: 8px;
  border: 1px solid #cee3ca;
  border-radius: 8px;
  padding: 6px 16px;
  color: #cee3ca;
  font-size: 14px;
  font-weight: 500;
  height: 36px;
  white-space: nowrap;
}

@media (min-width: 768px) {
  .header-nav {
    display: flex;
  }
}

#section-product-controls {
  padding: 40px 0 24px;
}

.page-header {
  margin-bottom: 32px;
}

.page-header h1 {
  font-size: 32px;
  font-weight: 700;
  margin: 0 0 16px 0;
  color: var(--color-text-dark);
}

.page-header .subtitle {
  font-size: 18px;
  color: var(--color-text-grey);
  margin: 0;
}

.controls-wrapper {
  display: flex;
  flex-direction: column;
  gap: 16px;
  margin-bottom: 24px;
}

.search-bar {
  width: 100%;
}

.search-input-wrapper {
  background-color: var(--color-white);
  border-radius: 8px;
  display: flex;
  align-items: center;
  padding: 8px 12px;
  height: 36px;
}

.search-icon {
  width: 20px;
  height: 20px;
  margin-right: 8px;
}

.search-input {
  border: none;
  outline: none;
  width: 100%;
  font-size: 14px;
  color: var(--color-text-grey);
}

.categories-bar {
  display: flex;
  align-items: center;
  gap: 12px;
  overflow-x: auto;
  padding-bottom: 8px; /* For scrollbar spacing if needed */
}

.category-label {
  font-weight: 600;
  color: var(--color-text-dark);
  white-space: nowrap;
}

.category-list {
  display: flex;
  gap: 8px;
}

.cat-btn {
  padding: 6px 12px;
  border-radius: 8px;
  font-size: 14px;
  white-space: nowrap;
  border: 1px solid var(--color-border);
  background-color: var(--color-bg-light);
  color: var(--color-text-dark);
  transition: all 0.2s;
}

.cat-btn.active {
  background-color: var(--color-primary);
  color: var(--color-white);
  border-color: var(--color-primary);
}

.results-count {
  font-size: 14px;
  color: var(--color-text-grey);
  margin-top: 8px;
}

@media (min-width: 1024px) {
  .controls-wrapper {
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
  }

  .search-bar {
    max-width: 300px;
  }
}

#section-product-grid {
  padding-bottom: 60px;
}

.product-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 24px;
}

.product-card {
  background-color: var(--color-white);
  border: 1px solid var(--color-border);
  border-radius: 14px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.card-image {
  width: 100%;
  height: 192px;
  background-color: #f5f5f0;
}

.card-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.card-content {
  padding: 24px;
  display: flex;
  flex-direction: column;
  flex-grow: 1;
  gap: 24px;
}

.card-header {
  display: flex;
  flex-direction: column;
}

.card-header h3 {
  margin: 0;
  font-size: 20px;
  font-weight: 700;
  color: var(--color-text-dark);
}

.producer-name {
  font-size: 14px;
  color: var(--color-text-grey);
  margin-top: 4px;
}

.product-desc {
  font-size: 14px;
  color: var(--color-text-dark);
  margin: 12px 0 0 0;
  line-height: 1.4;
}

.card-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: auto;
}

.price-block {
  display: flex;
  flex-direction: column;
}

.price {
  font-size: 24px;
  font-weight: 700;
  color: var(--color-primary);
}

.unit {
  font-size: 12px;
  color: var(--color-text-grey);
}

.stock-badge {
  background-color: var(--color-primary);
  color: var(--color-white);
  font-size: 12px;
  padding: 4px 8px;
  border-radius: 8px;
  font-weight: 500;
}

.btn-add-cart {
  background-color: var(--color-primary);
  color: var(--color-white);
  border-radius: 8px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  font-weight: 500;
  font-size: 14px;
  width: 100%;
  transition: opacity 0.2s;
}

.btn-add-cart:hover {
  opacity: 0.9;
}

.btn-add-cart img {
  width: 16px;
  height: 16px;
}

@media (min-width: 640px) {
  .product-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (min-width: 1024px) {
  .product-grid {
    grid-template-columns: repeat(4, 1fr);
  }
}

.site-footer {
  background-color: var(--color-secondary);
  color: var(--color-bg-light);
  padding: 64px 0 32px;
  border-top: 1px solid rgba(46, 46, 46, 0.3);
}

.footer-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 32px;
  margin-bottom: 48px;
}

.footer-col h4 {
  font-size: 18px;
  font-weight: 700;
  margin: 0 0 12px 0;
}

.footer-col p {
  font-size: 14px;
  line-height: 1.5;
  margin: 0;
  opacity: 0.9;
}

.contact-info p,
.hours-info p {
  margin-bottom: 4px;
}

.footer-bottom {
  border-top: 1px solid rgba(46, 46, 46, 0.3);
  padding-top: 24px;
  text-align: center;
}

.footer-bottom p {
  font-size: 14px;
  opacity: 0.8;
  margin: 0;
}

@media (min-width: 768px) {
  .footer-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

