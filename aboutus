:root {
  --primary-green: #2b4625;
  --accent-green: #cee3ca;
  --footer-brown: #a86a20;
  --text-dark: #2e2e2e;
  --text-light: #f5f5f0;
  --bg-white: #ffffff;
  --border-color: rgba(46, 46, 46, 0.1);
  --font-main: 'Inter', sans-serif;
}

body {
  font-family: var(--font-main);
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  color: var(--text-dark);
  background-color: #ffffff;
  -webkit-font-smoothing: antialiased;
}

*,
*::before,
*::after {
  box-sizing: inherit;
}

h1,
h2,
h3,
h4,
h5,
h6,
p {
  margin: 0;
}

a {
  text-decoration: none;
  color: inherit;
}

img {
  display: block;
  max-width: 100%;
}

.container {
  max-width: 1504px;
  margin: 0 auto;
  padding: 0 20px;
}

.btn {
  display: inline-flex;
  justify-content: center;
  align-items: center;
  padding: 10px 20px;
  border-radius: 8px;
  font-weight: 500;
  cursor: pointer;
  transition: opacity 0.2s;
}

.btn:hover {
  opacity: 0.9;
}

.btn-primary {
  background-color: var(--primary-green);
  color: white;
}

.btn-secondary {
  background-color: #f5f5f0;
  color: var(--text-dark);
  border: 1px solid var(--border-color);
}

.btn-outline {
  border: 1px solid var(--accent-green);
  color: var(--accent-green);
  background: transparent;
}

.btn-white {
  background-color: white;
  color: var(--primary-green);
}

@media (max-width: 1024px) {
  .container {
    padding: 0 24px;
  }
}

.site-header {
  background-color: var(--primary-green);
  color: var(--text-light);
  padding: 16px 0;
}

.header-container {
  max-width: 1504px;
  margin: 0 auto;
  padding: 0 20px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.logo-area {
  display: flex;
  align-items: center;
  gap: 8px;
}

.logo-icon {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-text h1 {
  font-size: 18px;
  font-weight: 700;
  line-height: 1.2;
}

.logo-text p {
  font-size: 12px;
  opacity: 0.5;
}

.main-nav {
  display: flex;
  gap: 24px;
}

.nav-link {
  font-size: 14px;
  font-weight: 500;
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 16px;
}

.icon-btn {
  background: none;
  border: none;
  cursor: pointer;
  padding: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.producer-login-btn {
  display: flex;
  align-items: center;
  gap: 8px;
  background: transparent;
  border: 1px solid var(--accent-green);
  color: var(--accent-green);
  padding: 6px 12px;
  border-radius: 8px;
  cursor: pointer;
  font-size: 14px;
}

@media (max-width: 900px) {
  .header-container {
    flex-direction: column;
    gap: 16px;
  }

  .main-nav {
    order: 2;
    width: 100%;
    justify-content: center;
  }

  .header-actions {
    order: 1;
    align-self: flex-end;
  }

  .logo-area {
    align-self: flex-start;
  }
}

#hero-section {
  background: linear-gradient(
    135deg,
    rgba(206, 227, 202, 0.3) 0%,
    rgba(206, 227, 202, 0.6) 100%
  );
  padding: 80px 0;
  overflow: hidden;
}

.hero-wrapper {
  max-width: 1665px;
  margin: 0 auto;
}

.hero-container {
  max-width: 1504px;
  margin: 0 auto;
  padding: 0 20px;
