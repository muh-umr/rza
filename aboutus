}

.view-all-container {
  text-align: center;
}

@media (max-width: 900px) {
  .producers-grid {
    grid-template-columns: 1fr;
  }
}

#commitment-section {
  padding: 80px 0;
  background-color: #fff;
}

.commitment-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 32px;
